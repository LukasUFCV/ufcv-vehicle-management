# Copier les valeurs backend dans backend/.env
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:4000
DATABASE_URL=mysql://rsvehicule:rsvehicule@localhost:3307/rsvehicule
SESSION_COOKIE_NAME=rsvehicule_session
SESSION_TTL_HOURS=12
SESSION_SECRET=replace_with_a_long_random_secret
CORS_ORIGIN=http://localhost:5173
UPLOAD_DIR=./storage/uploads
QR_CODE_DIR=./storage/qrcodes
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
SMTP_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ufcv.local
SEED_ADMIN_EMAIL=admin@ufcv.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_DEMO_PASSWORD=Demo123!

# Copier les valeurs frontend dans frontend/.env.local
VITE_APP_NAME=RSVehicule
VITE_API_BASE_URL=http://localhost:4000/api
